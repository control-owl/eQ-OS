[Unit]
Description=eQ Kiosk Application
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
User=eqos
Group=eqos
Environment=DISPLAY=:0
ExecStart=/usr/bin/xinit /usr/local/bin/eQ -- :0 vt1 -nolisten tcp -allowMouseOpenFail
Restart=no
RestartSec=5

[Install]
WantedBy=graphical.target