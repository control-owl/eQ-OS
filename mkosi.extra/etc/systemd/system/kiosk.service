[Unit]
Description=eQ Wallet Kiosk
After=systemd-user-sessions.service

[Service]
User=eqos
TTYPath=/dev/tty1
StandardInput=tty
StandardOutput=journal
StandardError=journal

ExecStart=/usr/local/bin/eQ

Restart=on-failure
RestartSec=1

TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

[Install]
WantedBy=multi-user.target